# ====== Conecta Tingo - Configuracion del servidor ======

# Charset UTF-8
AddDefaultCharset UTF-8

# Habilitar reporte de errores a archivo de log (no mostrar en pantalla)
php_flag display_errors Off
php_flag log_errors On
php_value error_log registro_de_errores

# Proteger archivos sensibles
<FilesMatch "\.(sql|log|bak|env|ini)$">
    Require all denied
</FilesMatch>

# Proteger archivo de errores
<Files "registro_de_errores">
    Require all denied
</Files>

# Proteger archivo de diagnostico (eliminar despues de verificar)
# <Files "diagnostico.php">
#     Require all denied
# </Files>

# Proteger directorio de configuracion y SEO
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
    RewriteRule ^app/config/ - [F,L]
    RewriteRule ^app/models/ - [F,L]
    RewriteRule ^app/controllers/ - [F,L]
</IfModule>

# Evitar listado de directorios
Options -Indexes

# Compresion GZIP para mejor rendimiento
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# Cache de archivos estaticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
</IfModule>
